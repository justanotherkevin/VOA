{
  "name": "voa",
  "version": "1.0.0",
  "description": "On-device meeting transcription and AI summarization for macOS — no cloud, no account required",
  "license": "MIT",
  "author": {
    "name": "Kevin Hu",
    "url": "https://github.com/justanotherkevin"
  },
  "contributors": [],
  "main": "./dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "start": "npm run dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "package": "npm run build && electron-builder build --publish never",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "BROWSERSLIST_IGNORE_OLD_DATA=true vitest run --config vitest.frontend.config.ts 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "test:backend": "vitest run --config vitest.backend.config.ts 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "test:backend:file": "vitest run --config vitest.backend.config.ts",
    "test:ui": "vitest --ui 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "test:e2e": "npm run build && playwright test --config playwright.config.ts",
    "test:e2e:build": "npm run build && playwright test --config=playwright.build.config.ts",
    "test:asr": "vitest run --config vitest.asr.config.ts src/main/__tests__/asr-accuracy.test.ts 2>&1 | ./scripts/filter-onnx-warnings.sh",
    "test:qwen": "vitest run --config vitest.qwen.config.ts src/main/__tests__/qwen-download.test.ts",
    "test:lmstudio": "vitest run --config vitest.lmstudio.config.ts src/main/__tests__/lmstudio-integration.test.ts",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "dependencies": {
    "@electron/notarize": "^3.0.0",
    "@headlessui/react": "^2.2.9",
    "@huggingface/transformers": "^3.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@ricky0123/vad-web": "^0.0.30",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-audio-loopback": "^1.0.6",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.3.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "onnxruntime-node": "^1.24.1",
    "onnxruntime-web": "^1.24.1",
    "radix-ui": "^1.6.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.13.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.0.4",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^27.2.0",
    "node-web-audio-api": "^2.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "react-refresh": "^0.16.0",
    "react-test-renderer": "19.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.86.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.9"
  },
  "build": {
    "productName": "VOA",
    "appId": "com.kevinhu.voa",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "afterSign": ".erb/scripts/notarize.js",
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "package.json"
    ],
    "mac": {
      "notarize": false,
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "We need access to your microphone to transcribe audio.",
        "NSAppleEventsUsageDescription": "We need to control other applications to paste the transcribed text.",
        "NSAccessibilityUsageDescription": "We need accessibility permissions to paste text into other applications."
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ]
  },
  "overrides": {
    "@huggingface/transformers": {
      "onnxruntime-node": "1.14.0"
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=14.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=7.x",
      "onFail": "error"
    }
  }
}
