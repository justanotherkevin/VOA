# E2E Test Configuration
# This file contains hardcoded variables for E2E tests

# Application name (from package.json)
VITE_APP_NAME=audio-to-text

# Store name for test isolation
VITE_STORE_NAME=audio-to-text-test

# Path to the app store directory
# electron-store saves to: ~/Library/Application Support/{VITE_APP_NAME}/
VITE_APP_STORE_PATH=~/Library/Application Support/audio-to-text-test

# Release app path
VITE_RELEASE_APP_PATH=../../release/app
